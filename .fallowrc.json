		"nodes/memory/RedisSessionMemory/RedisSessionMemory.node.ts",
		"nodes/memory/SimpleSessionMemory/SimpleSessionMemory.node.ts"
	],
	"ignoreDependencies": ["nodemailer"],
	"usedClassMembers": [
		{
			"implements": "ICredentialType",
			"members": [
				"name",
				"displayName",
				"documentationUrl",
				"icon",
				"properties",
				"authenticate",
				"test"
			]
		},
		{
			"implements": "INodeType",
			"members": ["description", "methods"]
		},
		{
			"implements": "SdkAdapter",
			"members": ["version", "createSession", "resumeSession"]
		},
		{
			"implements": "NotificationChannel",
			"members": ["name", "sendApproval", "sendQuestion"]
		},
		"generateRequestId",
		"getConfig"
	]
}
