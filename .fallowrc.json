	"entry": [
		"credentials/AlibabaCodingPlanApi.credentials.ts",
		"credentials/ClaudeApi.credentials.ts",
		"credentials/McpHeaderAuthApi.credentials.ts",
		"credentials/OllamaApi.credentials.ts",
		"credentials/OpenRouterApi.credentials.ts",
		"credentials/SecureEnvVarsApi.credentials.ts",
		"credentials/WhatsAppBusinessCloudApi.credentials.ts",
		"credentials/WoztellBotApi.credentials.ts",
		"nodes/ClaudeAgentSdk/ClaudeAgentSdk.node.ts",
		"nodes/ClaudeAgentSdk/sdk/parity.assertions.ts",
		"nodes/ClaudeSkillTool/ClaudeSkillTool.node.ts",
		"nodes/ClaudeAgentDiscord/ClaudeAgentDiscord.node.ts",
		"nodes/ClaudeAgentEmail/ClaudeAgentEmail.node.ts",
		"nodes/ClaudeAgentGmail/ClaudeAgentGmail.node.ts",
		"nodes/ClaudeAgentSlack/ClaudeAgentSlack.node.ts",
		"nodes/ClaudeAgentTelegram/ClaudeAgentTelegram.node.ts",
		"nodes/ClaudeAgentWhatsApp/ClaudeAgentWhatsApp.node.ts",
		"nodes/ClaudeAgentWoztell/ClaudeAgentWoztell.node.ts",
		"nodes/WoztellSend/WoztellSend.node.ts",
