# ============================================
# n8n + Claude Agent SDK — VPS Deployment
# ============================================
# Copy this file to .env and fill in the values.

# === REQUIRED ===

# Your domain (must point to this server's IP)
DOMAIN=n8n.example.com

# Anthropic API key for Claude. Prefer n8n credentials where possible.
ANTHROPIC_API_KEY=

# n8n encryption key (MUST persist across deploys!)
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Postgres password
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=

# Task runner auth token (shared between n8n and runners)
# Generate: openssl rand -hex 24
RUNNERS_AUTH_TOKEN=

# === OPTIONAL (have defaults) ===

# Postgres database name and user
POSTGRES_DB=n8n
POSTGRES_USER=n8n

# Immutable image refs published to GHCR (tag or digest).
N8N_IMAGE_REF=ghcr.io/example-owner/n8n-claude-sdk:v0.2.22
RUNNERS_IMAGE_REF=ghcr.io/example-owner/n8n-claude-sdk-runners:v0.2.22
CODE_SERVER_IMAGE_REF=ghcr.io/example-owner/n8n-claude-sdk-code-server:v0.2.22

# Grafana admin credentials
# Generate: openssl rand -base64 16
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# Timezone (used by some optional services)
TZ=Etc/UTC

# Queue concurrency cap for production mode
N8N_CONCURRENCY_PRODUCTION_LIMIT=5

# === TAILSCALE (private access to code-server + filebrowser) ===

# Tailscale auth key (MUST be reusable — three sidecar containers share it)
# Generate: Tailscale Admin → Settings → Keys → Generate auth key → check "Reusable"
TS_AUTHKEY=

# === DURABLE STREAM REPLAY (advanced overrides) ===
#
# Uncomment only if you need non-default table names or retention.
# CLAUDE_AGENT_STREAMS_TABLE=claude_streams
# CLAUDE_AGENT_STREAM_EVENTS_TABLE=claude_stream_events
# CLAUDE_AGENT_STREAM_RETENTION_HOURS=168

# === OPTIONAL (devtools profile) ===
#
# code-server (VS Code in the browser), served via Tailscale.
# If you enable the `devtools` profile, set one of the following (prefer hashed).
CODE_SERVER_PASSWORD=
CODE_SERVER_HASHED_PASSWORD=
